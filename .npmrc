# Configurações do pnpm
color=auto
shamefully-hoist=true
package-manager=pnpm@latest

# Configurações de cache (opcional, para ambientes CI/CD)
# Descomente se necessário em ambientes específicos:
# store-dir=${PODS_MANAGER_ROOT:-/app/cache}/.pnpm/store
# cache-dir=${PODS_MANAGER_ROOT:-/app/cache}/.pnpm/cache
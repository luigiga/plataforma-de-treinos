# Configurações do npm
color=auto
# Nota: shamefully-hoist, store-dir, cache-dir e package-manager são específicos do pnpm
# Se você usar pnpm no futuro, descomente essas linhas:
# shamefully-hoist=true
# store-dir=${PODS_MANAGER_ROOT:-/app/cache}/.pnpm/store
# cache-dir=${PODS_MANAGER_ROOT:-/app/cache}/.pnpm/cache
# package-manager=pnpm@latest
